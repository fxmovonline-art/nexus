// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// Enums
enum MeetingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

// User Model - For both Entrepreneurs and Investors
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  userType      String    @default("entrepreneur") // "entrepreneur" or "investor"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profile       Profile?
  startup       Startup?
  investments   Investment[]
  messages      Message[]
  entrepreneurMeetings Meeting[] @relation("entrepreneurMeetings")
  investorMeetings Meeting[] @relation("investorMeetings")

  @@map("users")
}

// Profile Model - Extended user information
model Profile {
  id            String    @id @default(cuid())
  bio           String?
  location      String?
  avatarUrl     String?
  phone         String?
  website       String?
  skills        String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Foreign Key
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// Startup Model
model Startup {
  id              String    @id @default(cuid())
  name            String
  description     String?
  industry        String
  fundingGoal     Float
  amountRaised    Float     @default(0)
  website         String?
  logo            String?
  location        String?
  teamSize        Int?
  pitchDeckUrl    String?
  pitchDeckName   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Foreign Key
  ownerId         String    @unique
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Relations
  investments     Investment[]
  team            TeamMember[]
  meetings        Meeting[]

  @@map("startups")
}

// Investment Model
model Investment {
  id                String    @id @default(cuid())
  amount            Float
  status            String    @default("PENDING") // COMPLETED, PENDING, FAILED
  stripeSessionId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Foreign Keys
  investorId        String
  investor          User      @relation(fields: [investorId], references: [id], onDelete: Cascade)

  startupId         String
  startup           Startup   @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("investments")
}

// Team Member Model
model TeamMember {
  id            String    @id @default(cuid())
  name          String
  role          String
  email         String?
  createdAt     DateTime  @default(now())

  // Foreign Key
  startupId     String
  startup       Startup   @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("team_members")
}

// Message Model
model Message {
  id            String    @id @default(cuid())
  text          String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Foreign Keys
  senderId      String
  sender        User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  recipientId   String

  @@map("messages")
}

// Meeting Model
model Meeting {
  id              String          @id @default(cuid())
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime
  status          MeetingStatus   @default(PENDING)
  location        String?
  meetingLink     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Foreign Keys
  investorId      String
  investor        User            @relation(fields: [investorId], references: [id], onDelete: Cascade, name: "investorMeetings")

  entrepreneurId  String
  entrepreneur    User            @relation(fields: [entrepreneurId], references: [id], onDelete: Cascade, name: "entrepreneurMeetings")

  startupId       String
  startup         Startup         @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("meetings")
}



